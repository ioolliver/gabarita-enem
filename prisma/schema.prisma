generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Question {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  command      String
  correct      Int
  identifier   String
  year         Int
  abilityCode  Int
  options      String[]
  languageType Int      @default(0)
  imageUrl     String   @default("")
  preCommand   String   @default("")
}

model List {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  abilityFilter Int[]
  languageFilter Int
  questions     String[]
  createdAt     DateTime @default(now())
}
